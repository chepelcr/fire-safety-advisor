# Copy to .env.local and fill in the values from the Cognito stack outputs:
#   bash deploys/deploy-cognito.sh dev   (in fire-code-cr-be repo)

VITE_AWS_REGION=us-east-1

# From export: jcampos-dev-fire-code-identity-pool-id
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# From export: jcampos-dev-fire-code-cognito-id
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# From export: jcampos-dev-fire-code-cognito-client-id
VITE_COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API base URL (custom domain after api-gateway stack is deployed)
VITE_API_BASE_URL=https://fire-code-api.jcampos.dev
